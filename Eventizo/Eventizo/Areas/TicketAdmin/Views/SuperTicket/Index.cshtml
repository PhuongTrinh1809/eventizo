@model List<Eventizo.Models.Event>

<style>
	body {
		background-color: #f8f9fa;
	}

	.sidebar {
		width: 220px;
		background-color: #343a40;
		padding: 20px;
		color: white;
	}

		.sidebar h4 {
			color: #f1c40f;
			margin-bottom: 30px;
		}

		.sidebar .nav-link {
			color: #fff;
			margin-bottom: 15px;
			display: block;
			font-size: 16px;
		}

			.sidebar .nav-link:hover {
				color: #f1c40f;
				text-decoration: none;
			}

	.content {
		padding: 30px;
		flex: 1;
	}

	.table td, .table th {
		vertical-align: middle;
	}
</style>

<div class="d-flex">
	<!-- Sidebar -->
	<nav class="sidebar">
		<h4>🎯 Quản lý</h4>
		<a asp-controller="SuperTicket" asp-action="Index" class="nav-link">Danh sách tổng số vé</a>
		<a asp-controller="SuperTicket" asp-action="Leftover" class="nav-link">Danh sách vé còn lại</a>
		<a asp-controller="SuperTicket" asp-action="Sold" class="nav-link">Danh sách vé đã bán</a>
		<a asp-controller="SuperTicket" asp-action="Canceled" class="nav-link">Danh sách vé đã hủy</a>
	</nav>

	<!-- Main content -->
	<div class="content">
		<h2 class="text-primary mb-4">Danh sách tổng số vé</h2>

		@if (Model == null || !Model.Any())
		{
			<div class="alert alert-warning mt-3">Chưa có sự kiện nào được tạo.</div>
		}
		else
		{
			<table class="table table-bordered table-hover text-center align-middle mt-3">
				<thead class="table-dark">
					<tr>
						<th>STT</th>
						<th>Tên sự kiện</th>
						<th>Loại sự kiện</th>
						<th>Số lượng vé</th>
						<th>Loại vé</th>
					</tr>
				</thead>
				<tbody>
					@{
						int stt = 1;
						var defaultTickets = new List<string> { "Thường", "VIP" };
					}

					@foreach (var ev in Model)
					{
						int rowCount = defaultTickets.Count;

						for (int i = 0; i < rowCount; i++)
						{
							<tr>
								@if (i == 0)
								{
									<td rowspan="@rowCount">@stt</td>
									<td rowspan="@rowCount">@ev.Name</td>
									<td rowspan="@rowCount">@ev.EventType?.Name</td>
									<td rowspan="@rowCount">@ev.Capacity</td>
								}
								<td>@defaultTickets[i]</td>
							</tr>
						}

						stt++;
					}
				</tbody>
			</table>
		}
	</div>
</div>
