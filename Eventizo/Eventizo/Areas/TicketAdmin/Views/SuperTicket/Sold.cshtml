@model List<Eventizo.Models.Ticket>
<style>
	body {
		background-color: #f8f9fa;
	}

	.sidebar {
		width: 220px;
		background-color: #343a40;
		padding: 20px;
		color: white;
	}

		.sidebar h4 {
			color: #f1c40f;
			margin-bottom: 30px;
		}

		.sidebar .nav-link {
			color: #fff;
			margin-bottom: 15px;
			display: block;
			font-size: 16px;
		}

			.sidebar .nav-link:hover {
				color: #f1c40f;
				text-decoration: none;
			}

	.content {
		padding: 30px;
		flex: 1;
	}

	.table td, .table th {
		vertical-align: middle;
	}

	.status-badge {
		padding: 5px 10px;
		border-radius: 12px;
		font-size: 13px;
	}

	.status-upcoming {
		background-color: #3498db;
		color: white;
	}

	.status-ongoing {
		background-color: #28a745;
		color: white;
	}

	.status-finished {
		background-color: #6c757d;
		color: white;
	}
</style>
<div class="d-flex">
	<!-- Sidebar -->
	<nav class="sidebar">
		<h4>🎯 Quản lý</h4>
		<a asp-controller="SuperTicket" asp-action="Index" class="nav-link">Danh sách tổng số vé</a>
		<a asp-controller="SuperTicket" asp-action="Leftover" class="nav-link">Danh sách vé còn lại</a>
		<a asp-controller="SuperTicket" asp-action="Sold" class="nav-link">Danh sách vé đã bán</a>
		<a asp-controller="SuperTicket" asp-action="Canceled" class="nav-link">Danh sách vé đã hủy</a>
	</nav>

	<!-- Main content -->
	<div class="content">
		<h2 class="mb-4">Danh sách tất cả vé đã bán</h2>

		@if (Model == null || !Model.Any())
		{
			<div class="alert alert-warning mt-3">Chưa có vé nào được bán.</div>
		}
		else
		{
			<table class="table table-bordered table-hover text-center align-middle mt-3">
				<thead class="table-dark">
					<tr>
						<th>STT</th>
						<th>Khách hàng</th>
						<th>Sự kiện</th>
						<th>Ngày sự kiện</th>
						<th>Thời gian</th>
						<th>Địa điểm</th>
						<th>Số ghế</th>
						<th>Loại vé</th>
						<th>Ngày đặt vé</th>
						<th>Phương thức</th>
					</tr>
				</thead>
				<tbody>
					@{
						int stt = 1;
					}
					@foreach (var ticket in Model)
					{
						<tr>
							<td>@stt</td>
							<td>@ticket.User?.FullName</td>
							<td>@ticket.Event?.Name</td>
							<td>@ticket.Event?.EventStartingDate.ToString("dd/MM/yyyy") - @ticket.Event?.EventEndingDate.ToString("dd/MM/yyyy")</td>
							<td>@ticket.Event?.Place</td>
							<td>@ticket.SeatNumber</td>
							<td>@ticket.TicketType</td>
							<td>@ticket.BookedAt.ToString("dd/MM/yyyy HH:mm")</td>
							<td>@ticket.PaymentMethod</td>
						</tr>
						stt++;
					}
				</tbody>
			</table>
		}
	</div>
</div>
