<style>
	body {
		background-color: #f8f9fa;
	}

	.sidebar {
		width: 220px;
		background-color: #343a40;
		padding: 20px;
		color: white;
	}

		.sidebar h4 {
			color: #f1c40f;
			margin-bottom: 30px;
		}

		.sidebar .nav-link {
			color: #fff;
			margin-bottom: 15px;
			display: block;
			font-size: 16px;
		}

			.sidebar .nav-link:hover {
				color: #f1c40f;
				text-decoration: none;
			}

	.content {
		padding: 30px;
		flex: 1;
	}

	.table td, .table th {
		vertical-align: middle;
	}

	.status-badge {
		padding: 5px 10px;
		border-radius: 12px;
		font-size: 13px;
	}

	.status-upcoming {
		background-color: #3498db;
		color: white;
	}

	.status-ongoing {
		background-color: #28a745;
		color: white;
	}

	.status-finished {
		background-color: #6c757d;
		color: white;
	}
</style>
<div class="d-flex">
	<!-- Sidebar -->
	<nav class="sidebar">
		<h4>🎯 Quản lý</h4>
		<a asp-controller="SuperTicket" asp-action="Index" class="nav-link">Danh sách tổng số vé</a>
		<a asp-controller="SuperTicket" asp-action="Leftover" class="nav-link">Danh sách vé còn lại</a>
		<a asp-controller="SuperTicket" asp-action="Sold" class="nav-link">Danh sách vé đã bán</a>
		<a asp-controller="SuperTicket" asp-action="Canceled" class="nav-link">Danh sách vé đã hủy</a>
	</nav>

	<!-- Main content -->
	<div class="content">
		<div class="d-flex justify-content-between align-items-center mb-4">
			<h2 class="text-primary">Quản lý vé</h2>
			<a href="#" class="btn btn-success">➕ Tạo vé mới</a>
		</div>

		<!-- Danh sách sự kiện -->
		<div class="card">
			<div class="card-header bg-light">
				<strong>Danh sách vé đã hủy</strong>
			</div>
			<div class="card-body p-0">
				<table class="table table-hover mb-0">
					<thead class="table-light">
						<tr>
							<th>#</th>
							<th>Tên vé</th>
							<th>Loại</th>
							<th>Giá</th>
							<th>Trạng thái</th>
							<th>Hành động</th>
						</tr>
					</thead>
					<tbody>
						<tr>
							<td>1</td>
							<td>Ticket 1</td>
							<td>Liveshow</td>
							<td>350.000</td>
							<td><span class="status-badge status-finished">Đã hủy</span></td>
							<td>
								<button class="btn btn-sm btn-warning">Chỉnh sửa</button>
								<button class="btn btn-sm btn-danger">Xóa</button>
							</td>
						</tr>
						<tr>
							<td>2</td>
							<td>Ticket 2</td>
							<td>Concert</td>
							<td>430.000</td>
							<td><span class="status-badge status-finished">Đã hủy</span></td>
							<td>
								<button class="btn btn-sm btn-warning">Chỉnh sửa</button>
								<button class="btn btn-sm btn-danger">Xóa</button>
							</td>
						</tr>
						<tr>
							<td>3</td>
							<td>Ticket 3</td>
							<td>Tour</td>
							<td>520.000</td>
							<td><span class="status-badge status-finished">Đã hủy</span></td>
							<td>
								<button class="btn btn-sm btn-warning">Chỉnh sửa</button>
								<button class="btn btn-sm btn-danger">Xóa</button>
							</td>
						</tr>
					</tbody>
				</table>
			</div>
		</div>
	</div>
</div>
