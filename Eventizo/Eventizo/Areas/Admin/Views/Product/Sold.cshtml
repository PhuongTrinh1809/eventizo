@model List<Eventizo.Models.Payment2>
@{
    ViewData["Title"] = "Đơn hàng đã bán";
}

<style>
    body {
        background-color: #f8f9fa;
    }

    .sidebar {
        width: 220px;
        background-color: #343a40;
        padding: 20px;
        color: white;
    }

        .sidebar h4 {
            color: #f1c40f;
            margin-bottom: 30px;
        }

        .sidebar .nav-link {
            color: #fff;
            margin-bottom: 15px;
            display: block;
            font-size: 16px;
        }

            .sidebar .nav-link:hover {
                color: #f1c40f;
                text-decoration: none;
            }

    .content {
        padding: 30px;
        flex: 1;
    }

    .table td, .table th {
        vertical-align: middle;
    }

    .status-badge {
        padding: 5px 10px;
        border-radius: 12px;
        font-size: 13px;
    }

    .status-confirmed {
        background-color: #28a745;
        color: white;
    }

    .status-cancelled {
        background-color: #dc3545;
        color: white;
    }
</style>

<div class="d-flex">
    <!-- Sidebar -->
    <nav class="sidebar">
        <h4>🎯 Quản lý</h4>
        <a asp-controller="SuperAdmin" asp-action="Index" class="nav-link">Danh sách doanh thu</a>
        <a asp-controller="EventType" asp-action="Index" class="nav-link">Quản lý loại sự kiện</a>
        <a asp-controller="Event" asp-action="Index" class="nav-link">Danh sách sự kiện</a>
        <a asp-controller="SuperAdmin" asp-action="Ticket" class="nav-link">Danh sách vé</a>
        <a asp-controller="Product" asp-action="Index" class="nav-link">Danh sách sản phẩm</a>
        <a asp-controller="Product" asp-action="Sold" class="nav-link">Đơn hàng đã bán</a>
        <a asp-controller="Customer" asp-action="Index" class="nav-link">Danh sách khách hàng</a>
        <a asp-controller="TicketManage" asp-action="Index" class="nav-link">Quản lý chỗ ngồi</a>
    </nav>

    <!-- Main content -->
    <div class="content">
        <h2 class="text-primary mb-4">📦 Danh sách đơn hàng đã bán</h2>

        @if (!Model.Any())
        {
            <div class="alert alert-info">Chưa có đơn hàng nào được bán.</div>
        }
        else
        {
            <table class="table table-bordered table-hover text-center align-middle mt-3">
                <thead class="table-dark">
                    <tr>
                        <th>STT</th>
                        <th>Tên sản phẩm</th>
                        <th>Số lượng</th>
                        <th>Tổng tiền</th>
                        <th>Ngày mua</th>
                        <th>Người mua</th>
                        <th>Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.Count; i++)
                    {
                        var order = Model[i];

                        // 👉 Pending / FAILED / NULL => Đã hủy
                        var displayStatus = order.OrderStatus == "SUCCESS"
                        ? "Đã xác nhận"
                        : "Đã hủy";

                        var statusClass = displayStatus == "Đã xác nhận"
                        ? "status-confirmed"
                        : "status-cancelled";

                        <tr>
                            <td>@(i + 1)</td>
                            <td>@order.Product?.Name</td>
                            <td>@order.Quantity</td>
                            <td>@order.TotalAmount.ToString("N0") VND</td>
                            <td>@order.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@order.User?.FullName (@order.User?.Email)</td>
                            <td>
                                <span class="status-badge @statusClass">@displayStatus</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
