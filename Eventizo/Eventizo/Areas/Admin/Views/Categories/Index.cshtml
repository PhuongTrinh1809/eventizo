@model IEnumerable<Eventizo.Models.Category>

<style>
	body {
		background-color: #f8f9fa;
	}

	.sidebar {
		height: 100vh;
		width: 220px;
		background-color: #343a40;
		padding: 20px;
		color: white;
	}

		.sidebar h4 {
			color: #f1c40f;
			margin-bottom: 30px;
		}

		.sidebar .nav-link {
			color: #fff;
			margin-bottom: 15px;
			display: block;
			font-size: 16px;
		}

			.sidebar .nav-link:hover {
				color: #f1c40f;
				text-decoration: none;
			}

	.content {
		padding: 30px;
		flex: 1;
	}

	.table td, .table th {
		vertical-align: middle;
	}

	.status-badge {
		padding: 5px 10px;
		border-radius: 12px;
		font-size: 13px;
	}

	.status-upcoming {
		background-color: #3498db;
		color: white;
	}

	.status-ongoing {
		background-color: #28a745;
		color: white;
	}

	.status-finished {
		background-color: #6c757d;
		color: white;
	}
</style>
<div class="d-flex">
	<!-- Sidebar -->
	<nav class="sidebar">
		<h4>🎯 Quản lý</h4>
		<a asp-controller="SuperAdmin" asp-action="Index" class="nav-link">Danh sách doanh thu</a>
		<a asp-controller="EventType" asp-action="Index" class="nav-link">Quản lý loại sự kiện</a>
		<a asp-controller="Event" asp-action="Index" class="nav-link">Danh sách sự kiện</a>
		<a asp-controller="SuperAdmin" asp-action="Ticket" class="nav-link">Danh sách vé</a>
		<a asp-controller="Product" asp-action="Index" class="nav-link">Danh sách sản phẩm</a>
		<a asp-controller="SuperAdmin" asp-action="Users" class="nav-link">Danh sách tham gia</a>
		<a asp-controller="TicketManage" asp-action="Index" class="nav-link">Quản lý chỗ ngồi</a>
	</nav>

	<!-- Main content -->
	<div class="content">
		<div class="d-flex justify-content-between align-items-center mb-4">
			<h2 class="text-primary">Quản lý loại sản phẩm</h2>
			<a href="~/admin/categories/add" class="btn btn-success">➕ Tạo loại sản phẩm mới</a>
		</div>

		<!-- Danh sách sự kiện -->
		<div class="card">
			<div class="card-header bg-light">
				<strong>Danh sách loại sản phẩm</strong>
			</div>
			<div class="card-body p-0">
				<table class="table table-hover mb-0">
					<thead class="table-light">
						<tr>
							<th>Tên Loại </th>
							<th>Hành động </th>
						</tr>
					</thead>
					<tbody>
						@foreach (var category in Model)
						{
							<tr>
								<td>@category.Name</td>
								<td>
									<button class="btn btn-sm btn-success" onclick="location.href='@Url.Action("Display", "Categories", new { id = category.Id })'">Xem</button> |
									<button class="btn btn-sm btn-warning" onclick="location.href='@Url.Action("Update", "Categories", new { id = category.Id })'">Sửa</button> |
									<button class="btn btn-sm btn-danger" onclick="location.href='@Url.Action("Delete", "Categories", new { id = category.Id })'">Xóa</button>
								</td>
							</tr>
						}
					</tbody>
				</table>
			</div>
		</div>
	</div>
</div>
