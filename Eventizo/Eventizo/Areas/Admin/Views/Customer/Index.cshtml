@model List<Eventizo.ViewModel.UserWithRoleViewModel>
@using Microsoft.AspNetCore.Mvc.Rendering

<style>
    body {
        background-color: #f8f9fa;
    }

    .sidebar {
        width: 220px;
        background-color: #343a40;
        padding: 20px;
        color: white;
    }

        .sidebar h4 {
            color: #f1c40f;
            margin-bottom: 30px;
        }

        .sidebar .nav-link {
            color: #fff;
            margin-bottom: 15px;
            display: block;
            font-size: 16px;
        }

            .sidebar .nav-link:hover {
                color: #f1c40f;
                text-decoration: none;
            }

    .content {
        padding: 30px;
        flex: 1;
    }

    .table td, .table th {
        vertical-align: middle;
    }

    .status-badge {
        padding: 5px 10px;
        border-radius: 12px;
        font-size: 13px;
    }

    .status-active {
        background-color: #28a745;
        color: white;
    }

    .status-disabled {
        background-color: #dc3545;
        color: white;
    }

    .action-form {
        display: inline-block;
        margin-right: 5px;
    }

    .role-select {
        width: auto;
        display: inline-block;
        vertical-align: middle;
    }
</style>

<div class="d-flex">
    <nav class="sidebar">
        <h4>🎯 Quản lý</h4>
        <a asp-controller="SuperAdmin" asp-action="Index" class="nav-link">Danh sách doanh thu</a>
        <a asp-controller="EventType" asp-action="Index" class="nav-link">Quản lý loại sự kiện</a>
        <a asp-controller="Event" asp-action="Index" class="nav-link">Danh sách sự kiện</a>
        <a asp-controller="SuperAdmin" asp-action="Ticket" class="nav-link">Danh sách vé</a>
        <a asp-controller="Product" asp-action="Index" class="nav-link">Danh sách sản phẩm</a>
        <a asp-controller="Product" asp-action="Sold" class="nav-link">Đơn hàng đã bán</a>
        <a asp-controller="Customer" asp-action="Index" class="nav-link">Danh sách khách hàng</a>
        <a asp-controller="TicketManage" asp-action="Index" class="nav-link">Quản lý chỗ ngồi</a>
    </nav>

    <div class="content">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="text-primary">Quản lý khách hàng</h2>
        </div>

        <table class="table table-bordered table-hover text-center align-middle mt-3">
            <thead class="table-dark">
                <tr>
                    <th>STT</th>
                    <th>Tên đăng nhập</th>
                    <th>Điểm</th> <!-- đổi Email thành Điểm -->
                    <th>Cấp bậc</th>
                    <th>Ngày tạo tài khoản</th>
                    <th>Chức vụ</th>
                    <th>Trạng thái</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="7">Không có khách hàng nào.</td></tr>
                }
                else
                {
                    int stt = 1;
                    foreach (var customer in Model)
                    {
                        <tr>
                            <td>@stt</td>
                            <td>@customer.FullName</td>
                            <td>@customer.Points</td> <!-- hiển thị điểm -->
                            <td>@customer.MemberLevel</td>
                            <td>@customer.CreatedDate.ToString("dd/MM/yyyy")</td>
                            <td>@customer.Role</td>
                            <td>
                                @if (customer.IsActive)
                                {
                                    <span class="status-badge status-active">Active</span>
                                }
                                else
                                {
                                    <span class="status-badge status-disabled">Disabled</span>
                                }
                            </td>
                            <td>
                                <!-- Form sửa quyền -->
                                <form asp-action="EditRole" method="post" class="action-form">
                                    <input type="hidden" name="userId" value="@customer.UserId" />
                                    <select name="selectedRole" class="form-select form-select-sm role-select">
                                        <option value="">-- Chọn quyền --</option>
                                        @foreach (SelectListItem role in (List<SelectListItem>)ViewBag.AllRoles)
                                        {
                                            if (customer.Role == role.Value)
                                            {
                                                <option value="@role.Value" selected>@role.Text</option>
                                            }
                                            else
                                            {
                                                <option value="@role.Value">@role.Text</option>
                                            }
                                        }
                                    </select>
                                    <button type="submit" class="btn btn-sm btn-warning ms-1">Lưu</button>
                                </form>

                                <!-- Disable / Enable tài khoản -->
                                @if (customer.IsActive)
                                {
                                    <form asp-action="DisableUser" method="post" class="action-form">
                                        <input type="hidden" name="userId" value="@customer.UserId" />
                                        <button type="submit" class="btn btn-sm btn-danger">Disable</button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-action="EnableUser" method="post" class="action-form">
                                        <input type="hidden" name="userId" value="@customer.UserId" />
                                        <button type="submit" class="btn btn-sm btn-success">Enable</button>
                                    </form>
                                }
                            </td>
                        </tr>
                        stt++;
                    }
                }
            </tbody>
        </table>

        <!-- PHÂN TRANG -->
        <div id="pagination" class="mt-3 d-flex justify-content-center"></div>

        <script>
            document.addEventListener("DOMContentLoaded", function () {
                const rowsPerPage = 10;
                const table = document.querySelector("table tbody");
                const rows = table.querySelectorAll("tr");
                const pagination = document.getElementById("pagination");

                const totalRows = rows.length;
                const totalPages = Math.ceil(totalRows / rowsPerPage);

                function showPage(page) {
                    rows.forEach(r => r.style.display = "none");
                    let start = (page - 1) * rowsPerPage;
                    let end = start + rowsPerPage;
                    for (let i = start; i < end && i < totalRows; i++) {
                        rows[i].style.display = "";
                    }
                    document.querySelectorAll(".page-btn").forEach(btn => btn.classList.remove("active-page"));
                    document.getElementById("page-" + page).classList.add("active-page");
                }

                function renderPagination() {
                    let html = "";
                    for (let i = 1; i <= totalPages; i++) {
                        html += `<button id="page-${i}" class="btn btn-sm btn-primary mx-1 page-btn">${i}</button>`;
                    }
                    pagination.innerHTML = html;
                    document.querySelectorAll(".page-btn").forEach(btn => {
                        btn.addEventListener("click", function () {
                            showPage(Number(this.textContent));
                        });
                    });
                }

                if (totalPages > 1) {
                    renderPagination();
                    showPage(1);
                }
            });
        </script>

        <style>
            #pagination {
                display: flex;
                justify-content: flex-end !important;
                margin-top: 10px;
                margin-right: 10px;
            }

            .page-btn {
                background-color: #ff7eb9;
                border: none;
                color: white;
                font-weight: bold;
                padding: 6px 12px;
                border-radius: 10px;
                transition: 0.2s;
            }

                .page-btn:hover {
                    background-color: #ff4fa3;
                    color: white;
                }

            .active-page {
                background-color: #ff4fa3 !important;
                color: white !important;
                border: none !important;
                box-shadow: 0 0 6px rgba(255,0,120,0.5);
            }
        </style>
    </div>
</div>