@model Eventizo.Models.EventType

<div class="container py-5">
    

    @if (Model.Events != null && Model.Events.Any())
    {
        <h4 class="mb-4 text-black">Sự kiện trong danh mục @Model.Name:</h4>
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var events in Model.Events)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0 rounded-3 hover-shadow">
                        @if (!string.IsNullOrEmpty(events.ImageUrl))
                        {
                            <img src="@Url.Content(events.ImageUrl)" class="card-img-top rounded-top" alt="@events.Name" style="object-fit: cover; height: 180px;" />
                        }
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title fw-semibold">@events.Name</h5>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info fw-semibold fs-5">Không có sự kiện nào trong danh mục này.</div>
    }

    <a asp-action="Index" class="btn btn-outline-primary mt-5 d-inline-flex align-items-center">
        <i class="bi bi-arrow-left-circle me-2 fs-5"></i> Trở lại danh sách
    </a>
</div>

<style>
    .hover-shadow:hover {
        box-shadow: 0 0.5rem 1rem rgb(0 0 0 / 0.15);
        transform: translateY(-4px);
        transition: all 0.3s ease;
    }

    .card-title.fw-semibold {
        font-weight: 600;
    }
</style>