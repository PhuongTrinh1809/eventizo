@model List<Eventizo.Models.Ticket>
@{
    ViewBag.Title = "Vé đã check-in";
}

<div class="d-flex">
    <!-- Sidebar -->
    <nav class="sidebar">
        <h4>🎯 Quản lý</h4>
        <a asp-controller="SuperUsers" asp-action="Index" class="nav-link">Danh sách tham gia</a>
        <a asp-controller="SuperUsers" asp-action="Concert" class="nav-link">Tham gia Concert</a>
        <a asp-controller="SuperUsers" asp-action="Liveshow" class="nav-link">Tham gia Liveshow</a>
        <a asp-controller="SuperUsers" asp-action="Tour" class="nav-link">Tham gia Tour</a>
        <a asp-area="UsersAdmin" asp-controller="CheckIn" asp-action="ViewTicketStatus" class="nav-link">Kiểm tra vé</a>
        <a asp-area="UsersAdmin" asp-controller="CheckIn" asp-action="Scan" class="nav-link">Scan vé</a>
    </nav>

    <!-- Main content -->
    <div class="content" style="padding:30px; flex:1;">
        <h2 class="text-primary">Danh sách vé đã check-in</h2>

        @if (!Model.Any())
        {
            <div class="alert alert-info">Chưa có vé nào được check-in.</div>
        }
        else
        {
            <table class="table table-striped">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Người dùng</th>
                        <th>Sự kiện</th>
                        <th>Ghế</th>
                        <th>Loại vé</th>
                        <th>Thời gian check-in</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.Count; i++)
                    {
                        var ticket = Model[i];
                        <tr>
                            <td>@(i + 1)</td>
                            <td>@(ticket.User?.UserName ?? "Khách")</td>
                            <td>@(ticket.Event?.Name ?? "Không xác định")</td>
                            <td>@ticket.SeatNumber</td>
                            <td>@ticket.TicketType</td>
                            <td>@ticket.CheckedInAt?.ToString("dd/MM/yyyy HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

<style>
    body {
        background-color: #f8f9fa;
    }

    .sidebar {
        width: 220px;
        background-color: #343a40;
        padding: 20px;
        color: white;
    }

        .sidebar h4 {
            color: #f1c40f;
            margin-bottom: 30px;
        }

        .sidebar .nav-link {
            color: #fff;
            margin-bottom: 15px;
            display: block;
            font-size: 16px;
        }

            .sidebar .nav-link:hover {
                color: #f1c40f !important;
                text-decoration: none;
            }

    .content {
        padding: 30px;
        flex: 1;
    }

    .table {
        background-color: white;
        border-radius: 8px;
        box-shadow: 0 2px 6px rgba(0,0,0,0.1);
    }
</style>
