@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<div class="content-card">
    <h3 class="account-title">
        <i class="bi bi-shield-lock-fill me-2"></i> @ViewData["Title"]
    </h3>

    <partial name="_StatusMessage" for="StatusMessage" />

    <div class="row justify-content-center">
        <div class="col-md-8">
            <form id="change-password-form" method="post" class="mt-3">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.OldPassword" class="form-control" autocomplete="current-password" aria-required="true" placeholder="Nhập mật khẩu cũ" />
                    <label asp-for="Input.OldPassword" class="form-label text-secondary">Mật khẩu hiện tại</label>
                    <span asp-validation-for="Input.OldPassword" class="text-danger small"></span>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.NewPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Nhập mật khẩu mới" />
                    <label asp-for="Input.NewPassword" class="form-label text-secondary">Mật khẩu mới</label>
                    <span asp-validation-for="Input.NewPassword" class="text-danger small"></span>
                </div>

                <div class="form-floating mb-4">
                    <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Xác nhận mật khẩu mới" />
                    <label asp-for="Input.ConfirmPassword" class="form-label text-secondary">Xác nhận mật khẩu mới</label>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="w-100 btn btn-lg btn-pink shadow-sm">
                    <i class="bi bi-check-circle-fill me-2"></i> Cập nhật mật khẩu
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    /* --- PASTE CSS CỦA BẠN VÀO ĐÂY (Đã giữ nguyên và tối ưu nhẹ) --- */

    /* 🌸 Màu hồng pastel chủ đạo */
    .text-pink {
        color: #d63384 !important;
    }

    /* 📌 Tiêu đề section */
    .account-title {
        color: #d63384;
        font-size: 1.5rem;
        font-weight: 700;
        margin-bottom: 1.5rem;
        border-bottom: 2px solid #ffe6ef;
        padding-bottom: 10px;
    }

    /* 🎀 Khung profile/email/password */
    .profile-container, .content-card {
        background: #fff;
        padding: 2.5rem; /* Tăng padding một chút cho thoáng */
        border-radius: 16px; /* Bo tròn nhiều hơn chút cho mềm mại */
        box-shadow: 0 10px 30px rgba(214, 51, 132, 0.15); /* Shadow mượt hơn */
        min-height: 460px;
        border: 1px solid rgba(214, 51, 132, 0.1);
    }

    /* 💾 Button chuẩn đồng bộ */
    .btn-pink {
        background-color: #d63384;
        border: none;
        color: white;
        font-weight: 600;
        padding: 12px 20px;
        border-radius: 8px;
        transition: all 0.3s ease;
    }

        .btn-pink:hover {
            background-color: #b42b6c;
            transform: translateY(-3px);
            box-shadow: 0 8px 15px rgba(214, 51, 132, 0.3);
            color: white;
        }

        .btn-pink:active {
            transform: translateY(-1px);
        }

    /* 💡 Input focus - Hiệu ứng glow hồng */
    .form-control {
        border-radius: 8px;
        border: 1px solid #e9ecef;
        padding: 1rem 0.75rem;
    }

        .form-control:focus {
            border-color: #f8a5c2;
            box-shadow: 0 0 0 0.25rem rgba(214, 51, 132, 0.15);
        }

    /* Floating label tinh chỉnh */
    .form-floating > label {
        padding: 1rem 0.75rem;
    }

    /* ⚠ Validation message */
    .text-danger.small {
        font-size: 0.85rem;
        margin-top: 4px;
        display: block;
        font-weight: 500;
    }

    /* --- Các class hỗ trợ layout khác (giữ nguyên từ code cũ của bạn) --- */
    .account-container {
        max-width: 1100px;
        margin: 0 auto;
    }

    /* Fix hiển thị icon nếu dùng Bootstrap Icons */
    .bi {
        vertical-align: -0.125em;
    }
</style>