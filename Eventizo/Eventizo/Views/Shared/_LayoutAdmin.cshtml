<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>Trang chủ - Quản lý sự kiện</title>
	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet">
	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
	<link rel="stylesheet" href="~/css/Style.css">
	<link rel="stylesheet" href="~/css/Chat.css" />
	@RenderSection("Styles", required: false)

</head>
<body>

	<!-- Navbar -->
	<nav class="navbar navbar-expand-lg navbar-dark">
		<div class="container">
			<a class="navbar-brand text-dark" href="@Url.Action("Index", "Home", new { area = "" })">
				Eventizo
			</a>
			<form class="d-flex input-group" style="max-width: 500px;" method="get" asp-area="" asp-controller="Home" asp-action="Search">
				<span class="input-group-text bg-white border-end-0">
					<svg xmlns="http://www.w3.org/2000/svg" height="15px" viewBox="0 -960 960 960" width="15px" fill="#6c757d">
						<path d="M784-120 532-372q-30 24-69 38t-83 14q-109 0-184.5-75.5T120-580q0-109 75.5-184.5T380-840q109 0 184.5 75.5T640-580q0 44-14 83t-38 69l252 252-56 56ZM380-400q75 0 127.5-52.5T560-580q0-75-52.5-127.5T380-760q-75 0-127.5 52.5T200-580q0 75 52.5 127.5T380-400Z">
						</path>
					</svg>
				</span>
				<input class="form-control border-start-0" type="search" name="searchTerm" placeholder="Bạn tìm gì hôm nay?">
				<button class="btn btn-light" type="submit">Tìm kiếm</button>
			</form>
			<button type="button" class="btn btn-outline-dark ms-3"
					onclick="window.location.href='/Admin/SuperAdmin/Index'">
				<svg xmlns="http://www.w3.org/2000/svg" height="30px" viewBox="0 -960 960 960" width="20px" fill="#1f1f1f">
					<path d="M376-318 480-397 584-318l-40-127 104-83H521.07L480-654l-41.07 126H312l104 83-40 127ZM168-192q-29.7 0-50.85-21.11Q96-234.22 96-263.86v-121.26q0-9.88 6.43-17.26 6.43-7.39 16.53-9.24Q141-419 154.5-437.5T168-480q0-24-13.5-42.5t-35.54-25.85q-10.1-1.84-16.53-9.19Q96-564.89 96-575v-121.19q0-29.62 21.15-50.71Q138.3-768 168-768h624q29.7 0 50.85 21.11Q864-725.78 864-696.14v121.26q0 9.88-6.43 17.26-6.43 7.39-16.53 9.24Q819-541 805.5-522.5T792-480q0 24 13.5 42.5t35.54 25.85q10.1 1.84 16.53 9.19Q864-395.11 864-385v121.19q0 29.62-21.15 50.71Q821.7-192 792-192H168Zm0-72h624v-91q-32-19-52-52t-20-73q0-40 20-73t52-52v-91H168v91q32 19 52 52t20 73q0 40-20 73t-52 52v91Zm312-216Z" />
				</svg>
				Quản lý tổng
			</button>
			<div class="d-flex">
				<partial name="_LoginPartial" />
			</div>
		</div>
	</nav>

	<!-- Danh mục sự kiện -->
	<div class="category-bar d-flex align-items-center gap-3">
		<a href="@Url.Action("Profile", "Home", new { area = "" })" class="menu-item">Giới thiệu</a>

		<div class="dropdown">
			<a class="btn dropdown-toggle" role="button" data-bs-toggle="dropdown" aria-expanded="false">
				Danh sách sự kiện
			</a>
			<ul class="dropdown-menu">
				<li>
					<a class="dropdown-item" href="@Url.Action("Tour", "Home", new { area = "" })">
						Tour
					</a>
				</li>
				<li>
					<a class="dropdown-item" href="@Url.Action("Concert", "Home", new { area = "" })">
						Concert
					</a>
				</li>
				<li>
					<a class="dropdown-item" href="@Url.Action("LiveShow", "Home", new { area = "" })">
						LiveShow
					</a>
				</li>
			 </ul> 
		</div>

		<a href="@Url.Action("InMonth", "Home", new { area = "" })">Sự kiện sắp tới</a>
		<a href="@Url.Action("Product", "Home", new { area = "" })">Sản phẩm</a>
		<a href="@Url.Action("Index", "Chat", new { area = "Admin" })">Quản lý Chat</a>


	</div>

	<div class="container-fluid">
		<main role="main" class="pb-3">
			@RenderBody()
		</main>
	</div>

	<!-- Footer -->
	<footer class="footer">
		<div class="footer-column-1">
			<h3>Hotline</h3>
			<p>📞 Thứ 2 - Thứ 6 (8:30 - 22:00)</p>
			<p class="highlight">1900843652</p>
			<h3>Email</h3>
			<p>📧 support@eventizo.vn</p>
			<h3>Văn phòng</h3>
			<p>📍 Quận 1, TP. Hồ Chí Minh</p>
		</div>

		<div class="footer-column-2">
			<h3>Dành cho Khách hàng</h3>
			<a href="#">Điều khoản sử dụng cho khách hàng</a>
			<h3>Dành cho Ban Tổ chức</h3>
			<a href="#">Điều khoản sử dụng cho ban tổ chức</a>
			@* <h3>Đăng ký nhận email về sự kiện hot nhất</h3> *@
			@* <div class="email-box"> *@
			@* 	<input type="email" placeholder="Your Email"> *@
			@* 	<button>➡</button> *@
			@* </div> *@
		</div>

		<div class="footer-column-3">
			<h3>Về công ty chúng tôi</h3>
			<a href="#">Quy chế hoạt động</a>
			<a href="#">Chính sách bảo mật thông tin</a>
			<a href="#">Cơ chế giải quyết tranh chấp</a>
			<a href="#">Chính sách bảo mật thanh toán</a>
			<a href="#">Chính sách đổi trả vé</a>
			<a href="#">Phương thức thanh toán</a>
		</div>
	</footer>

	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
	<script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/2.11.8/umd/popper.min.js"></script>
	<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
	<script>
		var swiper = new Swiper(".mySwiper", {
			slidesPerView: 1,
			spaceBetween: 20,
			loop: false,
			autoplay: {
				delay: 3000,
				disableOnInteraction: false,
			},
			navigation: {
				nextEl: ".swiper-button-next",
				prevEl: ".swiper-button-prev",
			},
			breakpoints: {
				768: { slidesPerView: 2 },
				1024: { slidesPerView: 3 },
				1200: { slidesPerView: 4 }
			}
		});
	</script>

	<script src="~/lib/jquery/dist/jquery.min.js"></script>
	<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
	<script src="~/js/site.js" asp-append-version="true"></script>
	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
	@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
