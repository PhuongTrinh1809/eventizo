@model Eventizo.Models.Ticket
@{
    ViewData["Title"] = "Chuyển nhượng vé";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<style>
    .transfer-container {
        max-width: 500px;
        margin: 60px auto;
        background: #fff;
        border-radius: 16px;
        padding: 30px;
        box-shadow: 0 8px 30px rgba(255, 97, 133, 0.3);
    }

    h2 {
        text-align: center;
        color: #FF6185;
        font-weight: 700;
        margin-bottom: 25px;
    }

    .ticket-info {
        background: #ffeef2;
        border-radius: 12px;
        padding: 15px;
        margin-bottom: 25px;
    }

    .btn-transfer {
        background-color: #ff6185;
        border: none;
        color: white;
        border-radius: 8px;
        padding: 10px 18px;
        font-weight: 600;
        width: 100%;
        transition: 0.3s;
    }

        .btn-transfer:hover {
            background-color: #e94e70;
        }

    .scroll-box {
        max-height: 300px;
        overflow-y: auto;
        border: 1px solid #ddd;
        border-radius: 8px;
        padding: 15px;
        background-color: #fff9fb;
    }

        .scroll-box::-webkit-scrollbar {
            width: 8px;
        }

        .scroll-box::-webkit-scrollbar-thumb {
            background-color: #ff6185;
            border-radius: 8px;
        }
</style>

<div class="transfer-container">
    <h2>Chuyển nhượng vé</h2>

    <div class="ticket-info">
        <p>🎟️ <strong>Ghế:</strong> @Model.SeatNumber</p>
        <p>📅 <strong>Sự kiện:</strong> @Model.Event?.Name</p>
        <p>💰 <strong>Giá vé:</strong> @Model.Price.ToString("N0") VND</p>
    </div>

    <form id="transferForm" asp-action="TransferTicket" asp-controller="Ticket" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="ticketId" value="@Model.Id" />

        <div class="mb-3">
            <label for="email" class="form-label">Email người nhận</label>
            <input type="email" class="form-control" id="email" name="newOwnerEmail" required placeholder="Nhập email người nhận vé" />
        </div>

        <div class="mb-3">
            <label class="form-label">Tên ngân hàng</label>
            <input type="text" class="form-control" name="BankName" required placeholder="VD: Vietcombank" />
        </div>

        <div class="mb-3">
            <label class="form-label">Số tài khoản</label>
            <input type="text" class="form-control" name="BankAccountNumber" required placeholder="Nhập số tài khoản" />
        </div>

        <div class="mb-3">
            <label class="form-label">Chủ tài khoản</label>
            <input type="text" class="form-control" name="BankAccountOwner" required placeholder="Tên chủ tài khoản" />
        </div>

        <button type="button" class="btn-transfer" id="btnShowRules">Xác nhận chuyển nhượng</button>
    </form>

    <a asp-controller="Home" asp-action="MyTickets" class="d-block text-center mt-3 text-decoration-none">⬅ Quay lại danh sách vé</a>
</div>

<!-- 🧾 Modal Quy định chuyển nhượng -->
<div class="modal fade" id="transferRulesModal" tabindex="-1" aria-labelledby="transferRulesLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content rounded-4">
            <div class="modal-header bg-light">
                <h5 class="modal-title fw-bold text-danger" id="transferRulesLabel">🎟️ HỢP ĐỒNG CHUYỂN NHƯỢNG VÉ</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>

            <div class="modal-body">
                <!-- 🧾 Hộp nội dung điều khoản -->
                <div id="contractBox" class="scroll-box border rounded p-3" style="max-height: 350px; overflow-y: auto; background-color: #fff9fa;">
                    <h6 class="fw-bold text-center mb-3 text-danger">
                        HỢP ĐỒNG & ĐIỀU KHOẢN CHUYỂN NHƯỢNG VÉ
                    </h6>

                    <p><strong>1️⃣ Phạm vi và tỷ lệ chuyển nhượng</strong></p>
                    <ul>
                        <li>Điều khoản này áp dụng cho <strong>người sở hữu vé</strong> khi thực hiện chuyển nhượng qua hệ thống Eventizo.</li>
                        <li>Sau khi hoàn tất, bạn sẽ nhận lại <strong>90% giá trị vé</strong>.</li>
                        <li><strong>10%</strong> còn lại là <strong>phí xử lý</strong> cho hệ thống, đảm bảo giao dịch minh bạch và an toàn.</li>
                        <li>Vé chỉ được phép chuyển <strong>một lần duy nhất</strong>. Sau khi chuyển, bạn <strong>không thể sử dụng</strong>.</li>
                    </ul>

                    <p><strong>2️⃣ Quy trình chuyển nhượng</strong></p>
                    <p><u>Bước 1: Người A (chuyển nhượng)</u></p>
                    <ul>
                        <li>Chọn vé muốn chuyển → nhập thông tin người nhận (email hoặc tài khoản Eventizo).</li>
                        <li>Đọc toàn bộ điều khoản này đến hết và tick ✅ “Tôi đồng ý điều khoản 90/10”.</li>
                        <li>Nhấn “Xác nhận chuyển nhượng”.</li>
                        <li>Vé của bạn được tạm giữ, chuyển sang trạng thái <strong>“Đang chờ người nhận xác nhận”</strong>.</li>
                    </ul>

                    <p><u>Bước 2: Người B (người được chuyển)</u></p>
                    <ul>
                        <li>Nhận thông báo qua email và hệ thống Eventizo.</li>
                        <li>Người B có <strong>24 giờ</strong> để xác nhận.</li>
                        <ul>
                            <li>✅ Nếu chấp nhận → chuyển đến trang thanh toán.</li>
                            <li>Sau khi thanh toán xong → hệ thống hoàn 90% giá trị vé cho bạn.</li>
                            <li>❌ Nếu từ chối → vé trở lại quyền sở hữu của bạn, không phát sinh chi phí.</li>
                        </ul>
                    </ul>

                    <p><u>Bước 3: Quá hạn xác nhận</u></p>
                    <ul>
                        <li>Nếu người nhận không phản hồi trong 24h, giao dịch tự động hủy.</li>
                        <li>Vé trở lại quyền sở hữu của bạn, không phát sinh bất kì chi phí nào.</li>
                    </ul>

                    <p><strong>3️⃣ Cam kết của người chuyển nhượng</strong></p>
                    <ul>
                        <li>Vé bạn chuyển là hợp lệ, chưa qua sử dụng và không vi phạm điều kiện sự kiện.</li>
                        <li>Sau khi hoàn tất, bạn đồng ý từ bỏ toàn bộ quyền lợi và khiếu nại liên quan đến vé.</li>
                        <li>Hệ thống Eventizo chỉ đóng vai trò trung gian, không chịu trách nhiệm cho tranh chấp cá nhân.</li>
                        <li>Tất cả giao dịch được ghi lại vĩnh viễn để đảm bảo tính minh bạch.</li>
                    </ul>

                    <p><strong>4️⃣ Xác nhận cuối cùng</strong></p>
                    <p>
                        Bằng việc tích vào ô “Tôi đồng ý”, bạn xác nhận rằng đã đọc hết, hiểu rõ và chấp thuận toàn bộ các điều khoản chuyển nhượng (tỷ lệ 90/10).
                        Hành động này được xem là xác nhận ký kết hợp đồng điện tử hợp lệ giữa bạn và hệ thống Eventizo.
                    </p>
                </div>

                <!-- ✅ Checkbox chỉ bật sau khi đọc hết -->
                <div class="form-check mt-3">
                    <input class="form-check-input" type="checkbox" id="agreeCheckbox" disabled>
                    <label class="form-check-label" for="agreeCheckbox">
                        Tôi đã đọc hết và đồng ý với quy định chuyển nhượng (tỷ lệ 90/10).
                    </label>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-danger" id="btnConfirmTransfer" disabled>Xác nhận chuyển nhượng</button>
            </div>
        </div>
    </div>
</div>

<script>
    // Khi nhấn "Xác nhận chuyển nhượng" trong form
    document.getElementById("btnShowRules").addEventListener("click", function () {
        const email = document.getElementById("email").value.trim();
        if (email === "") {
            alert("Vui lòng nhập email người nhận trước khi tiếp tục.");
            return;
        }
        const modal = new bootstrap.Modal(document.getElementById("transferRulesModal"));
        modal.show();
    });

    const scrollBox = document.getElementById("contractBox");
    const checkbox = document.getElementById("agreeCheckbox");
    const confirmBtn = document.getElementById("btnConfirmTransfer");

    // Chỉ bật checkbox khi kéo đến cuối
    scrollBox.addEventListener("scroll", function () {
        if (scrollBox.scrollTop + scrollBox.clientHeight >= scrollBox.scrollHeight - 10) {
            checkbox.disabled = false;
        }
    });

    // Khi tích vào ô đồng ý
    checkbox.addEventListener("change", function () {
        confirmBtn.disabled = !this.checked;
    });

    // Khi nhấn xác nhận cuối cùng
    confirmBtn.addEventListener("click", function () {
        document.getElementById("transferForm").submit();
    });
</script>