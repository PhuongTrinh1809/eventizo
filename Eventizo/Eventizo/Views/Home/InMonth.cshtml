@model List<Eventizo.Models.Event>

@{
    ViewData["Title"] = "All Events";
}

<div class="container py-4">

    <div class="d-flex align-items-center justify-content-between mb-3">
        <h3 class="fw-bold text-primary"><i class="bi bi-geo-alt-fill"></i> Tour Sắp Diễn Ra</h3>
        <hr class="flex-grow-1 ms-3" />
    </div>

    <div class="row row-cols-1 row-cols-md-3 g-4 mb-5">
        @foreach (var events in Model.Where(e => e.EventType?.Name == "Tour" && e.Status == "Sắp diễn ra"))
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0 hover-shadow">
                    <div class="position-relative">
                        <a asp-action="DetailsTour" asp-controller="Home" asp-route-id="@events.Id">
                            <img src="@Url.Content(events.ImageUrl)" class="card-img-top" style="height: 250px; object-fit: cover;" alt="@events.Name" />
                        </a>
                        <div class="position-absolute top-0 end-0 p-2">
                            @if (events.Status == "Sắp diễn ra")
                            {
                                <span class="badge bg-success shadow">Sắp diễn ra</span>
                            }
                            else if (events.Status == "Đang diễn ra")
                            {
                                <span class="badge bg-warning text-dark shadow">Đang diễn ra</span>
                            }
                            else
                            {
                                <span class="badge bg-danger shadow">Đã diễn ra</span>
                            }
                        </div>
                    </div>

                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title fw-bold text-truncate" title="@events.Name">@events.Name</h5>
                        <p class="card-text text-muted small mb-2"><i class="bi bi-geo-alt"></i> @events.Place</p>
                        <p class="card-text flex-grow-1">@events.Description</p>
                        <a asp-action="DetailsTour" asp-route-id="@events.Id" class="btn btn-primary mt-auto w-100">Chi tiết Tour</a>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="d-flex align-items-center justify-content-between mb-3">
        <h3 class="fw-bold text-danger"><i class="bi bi-music-note-beamed"></i> Liveshow Sắp Diễn Ra</h3>
        <hr class="flex-grow-1 ms-3" />
    </div>

    <div class="row row-cols-1 row-cols-md-3 g-4 mb-5">
        @foreach (var events in Model.Where(e => e.EventType?.Name == "Liveshow" && e.Status == "Sắp diễn ra"))
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0 hover-shadow">
                    <div class="position-relative">
                        @if (!string.IsNullOrEmpty(events.ImageUrl))
                        {
                            <a asp-action="DetailsLiveshow" asp-controller="Home" asp-route-id="@events.Id">
                                <img src="@Url.Content(events.ImageUrl)" class="card-img-top" style="height: 250px; object-fit: cover;" alt="@events.Name" />
                            </a>
                        }
                        <div class="position-absolute top-0 end-0 p-2">
                            <span class="badge bg-success shadow">Sắp diễn ra</span>
                        </div>
                    </div>
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title fw-bold text-truncate" title="@events.Name">@events.Name</h5>
                        <p class="card-text text-muted small mb-2">@events.Description</p>
                        <a asp-action="DetailsLiveshow" asp-route-id="@events.Id" class="btn btn-outline-danger mt-auto w-100">Chi tiết Liveshow</a>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="d-flex align-items-center justify-content-between mb-3">
        <h3 class="fw-bold text-warning text-dark"><i class="bi bi-speaker-fill"></i> Concert Sắp Diễn Ra</h3>
        <hr class="flex-grow-1 ms-3" />
    </div>

    <div class="row row-cols-1 row-cols-md-3 g-4 mb-5">
        @foreach (var events in Model.Where(e => e.EventType?.Name == "Concert" && e.Status == "Sắp diễn ra"))
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0 hover-shadow">
                    <div class="position-relative">
                        @if (!string.IsNullOrEmpty(events.ImageUrl))
                        {
                            <a asp-action="DetailsConcert" asp-controller="Home" asp-route-id="@events.Id">
                                <img src="@Url.Content(events.ImageUrl)" class="card-img-top" style="height: 250px; object-fit: cover;" alt="@events.Name" />
                            </a>
                        }
                        <div class="position-absolute top-0 end-0 p-2">
                            <span class="badge bg-success shadow">Sắp diễn ra</span>
                        </div>
                    </div>
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title fw-bold text-truncate" title="@events.Name">@events.Name</h5>
                        <p class="card-text text-muted small mb-2">@events.Description</p>
                        <a asp-action="DetailsConcert" asp-route-id="@events.Id" class="btn btn-outline-dark mt-auto w-100">Chi tiết Concert</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .hover-shadow {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .hover-shadow:hover {
            transform: translateY(-5px);
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.15) !important;
        }
</style>