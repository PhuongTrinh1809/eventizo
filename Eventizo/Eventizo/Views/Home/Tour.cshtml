@model List<Eventizo.Models.Event>

@{
    ViewData["Title"] = "Tour";

    // Logic sắp xếp GIỮ NGUYÊN
    var sortedEvents = Model
        .Where(e => e.EventType != null && e.EventType.Name == "Tour")
        .OrderBy(e => e.Status == "Sắp diễn ra" ? 1 :
                      e.Status == "Đang diễn ra" ? 2 : 3);
}

<div class="container py-5">
    <div class="d-flex align-items-center mb-4 border-bottom pb-3">
        <h2 class="fw-bold text-primary m-0">DANH SÁCH TOUR</h2>
        <span class="ms-3 badge bg-secondary rounded-pill">@sortedEvents.Count() sự kiện</span>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var events in sortedEvents)
        {
            <div class="col">
                <div class="card h-100 shadow border-0 tour-card-hover rounded-4">

                    <div class="position-relative overflow-hidden rounded-top-4">
                        <a asp-action="DetailsTour" asp-controller="Home" asp-route-id="@events.Id">
                            <img src="@Url.Content(events.ImageUrl)" class="card-img-top tour-img-zoom" alt="@events.Name" />
                        </a>

                        <div class="position-absolute top-0 end-0 p-3">
                            @if (events.Status == "Sắp diễn ra")
                            {
                                <span class="badge bg-success shadow fs-6">Sắp diễn ra</span>
                            }
                            else if (events.Status == "Đang diễn ra")
                            {
                                <span class="badge bg-warning text-dark shadow fs-6">Đang diễn ra</span>
                            }
                            else
                            {
                                <span class="badge bg-danger shadow fs-6">Đã diễn ra</span>
                            }
                        </div>
                    </div>

                    <div class="card-body d-flex flex-column text-center p-4">
                        <h5 class="card-title fw-bold text-dark title-clamp" title="@events.Name">
                            @events.Name
                        </h5>

                        <p class="card-text text-muted fs-6 mb-3 text-truncate">
                            <i class="bi bi-geo-alt-fill text-danger me-1"></i>@events.Place
                        </p>

                        <div class="mt-auto w-100">
                            <a asp-action="DetailsTour" asp-route-id="@events.Id" class="btn btn-primary w-100 py-2 fw-bold rounded-pill shadow-sm">
                                XEM CHI TIẾT
                            </a>
                        </div>
                    </div>

                </div>
            </div>
        }
    </div>
</div>

<style>
    /* 1. Cố định chiều cao ảnh lớn hơn (250px) */
    .card-img-top {
        height: 250px;
        width: 100%;
        object-fit: cover;
        transition: transform 0.6s ease;
    }

    /* 2. Hiệu ứng Zoom mượt mà */
    .tour-card-hover:hover .tour-img-zoom {
        transform: scale(1.1);
    }

    /* 3. Hiệu ứng Card nổi lên */
    .tour-card-hover {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        background-color: #fff;
    }

        .tour-card-hover:hover {
            transform: translateY(-8px); /* Nổi cao hơn chút */
            box-shadow: 0 1rem 3rem rgba(0,0,0,.15) !important;
        }

    /* 4. Xử lý Tên sự kiện: To và giới hạn 2 dòng */
    .title-clamp {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        font-size: 1.35rem; /* Cỡ chữ to hơn (khoảng 21px) */
        line-height: 1.3; /* Khoảng cách dòng thoáng */
        height: 2.6em; /* Chiều cao cố định tương ứng với 2 dòng */
        margin-bottom: 0.75rem;
    }
</style>