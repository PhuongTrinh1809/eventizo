@model IEnumerable<Eventizo.Models.Event>

@{
    ViewData["Title"] = "Concert";

    // Logic sắp xếp: GIỮ NGUYÊN
    var sortedEvents = Model
        .Where(e => e.EventType.Name == "Concert")
        .OrderBy(e => e.Status == "Sắp diễn ra" ? 1 :
                      e.Status == "Đang diễn ra" ? 2 : 3)
        .ToList();
}

<div class="container py-5">
    <div class="d-flex align-items-center mb-4 border-bottom pb-3">
        <h2 class="fw-bold text-danger m-0">DANH SÁCH CONCERT</h2>
        <span class="ms-3 badge bg-secondary rounded-pill">@sortedEvents.Count() sự kiện</span>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var ev in sortedEvents)
        {
            <div class="col">
                <div class="card h-100 shadow border-0 concert-card-hover rounded-4">

                    <div class="position-relative overflow-hidden rounded-top-4">
                        <a asp-action="DetailsConcert" asp-controller="Home" asp-route-id="@ev.Id">
                            <img src="@Url.Content(ev.ImageUrl)" class="card-img-top concert-img-zoom" alt="@ev.Name" />
                        </a>

                        <div class="position-absolute top-0 end-0 p-3">
                            @if (ev.Status == "Sắp diễn ra")
                            {
                                <span class="badge bg-success shadow fs-6">Sắp diễn ra</span>
                            }
                            else if (ev.Status == "Đang diễn ra")
                            {
                                <span class="badge bg-warning text-dark shadow fs-6">Đang diễn ra</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary shadow fs-6">Đã diễn ra</span>
                            }
                        </div>
                    </div>

                    <div class="card-body d-flex flex-column text-center p-4">
                        <h5 class="card-title fw-bold text-dark title-clamp" title="@ev.Name">
                            @ev.Name
                        </h5>

                        <p class="card-text text-muted fs-6 mb-3">
                            <i class="bi bi-calendar-event text-danger me-2"></i>
                            <span class="fw-semibold">@ev.EventStartingDate.ToString("dd/MM/yyyy")</span>
                        </p>

                        <div class="mt-auto w-100">
                            <a asp-action="DetailsConcert" asp-route-id="@ev.Id" class="btn btn-danger w-100 py-2 fw-bold rounded-pill shadow-sm custom-btn-pink">
                                XEM CHI TIẾT
                            </a>
                        </div>
                    </div>

                </div>
            </div>
        }
    </div>
</div>

<style>
    /* 1. Cố định chiều cao ảnh 250px (Giống Tour) */
    .card-img-top {
        height: 250px;
        width: 100%;
        object-fit: cover; /* Quan trọng: cắt ảnh thừa để vừa khung */
        transition: transform 0.6s ease;
    }

    /* 2. Hiệu ứng Zoom ảnh */
    .concert-card-hover:hover .concert-img-zoom {
        transform: scale(1.1);
    }

    /* 3. Hiệu ứng Card nổi lên */
    .concert-card-hover {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        background-color: #fff;
    }

        .concert-card-hover:hover {
            transform: translateY(-8px);
            box-shadow: 0 1rem 3rem rgba(0,0,0,.15) !important;
        }

    /* 4. Tên sự kiện To và giới hạn 2 dòng */
    .title-clamp {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        font-size: 1.35rem; /* Cỡ chữ to (~22px) */
        line-height: 1.3;
        height: 2.6em; /* Chiều cao cố định */
        margin-bottom: 0.75rem;
    }

    /* 5. Tùy chỉnh màu nút bấm Concert (Hồng/Đỏ) */
    .custom-btn-pink {
        background-color: #dc3545; /* Đỏ bootstrap mặc định */
        border-color: #dc3545;
    }
    /* Nếu bạn muốn giữ màu hồng cũ (#FF69B4) thì bỏ comment đoạn dưới này: */
    /*
            .custom-btn-pink {
                background-color: #FF69B4 !important;
                border-color: #FF69B4 !important;
            }
            .custom-btn-pink:hover {
                background-color: #ff4da6 !important;
            }
            */
</style>