@model List<Eventizo.Models.Event>

@{
    ViewData["Title"] = "All";
}

<!-- Events -->
<div class="row row-cols-1 row-cols-md-3 g-4">
    @foreach (var events in Model.Where(e => e.EventType != null && e.EventType.Name == "Tour"))
    {
        <div class="col-md-12 mb-4">
            <div class="card h-100 shadow d-flex flex-row">
                <!-- Ảnh bên trái: 2/3 -->
                <a asp-action="DetailsTour" asp-controller="Home" asp-route-id="@events.Id" style="width: 66.66%;">
                    <img src="@Url.Content(events.ImageUrl)" class="img-fluid h-100" style="object-fit: cover;" alt="@events.Name" />
                </a>

                <!-- Nội dung bên phải: 1/3 -->
                <div class="card-body d-flex flex-column justify-content-between" style="width: 33.33%;">
                    <h5 class="card-title">@events.Name</h5>
                    <p class="card-text">Địa điểm: @events.Place</p>
                    <p class="card-text">
                        @if (events.Status == "Sắp diễn ra")
                        {
                            <span class="badge bg-success">Sắp diễn ra</span>
                        }
                        else if (events.Status == "Đang diễn ra")
                        {
                            <span class="badge bg-warning text-dark">Đang diễn ra</span>
                        }
                        else if (events.Status == "Đã diễn ra")
                        {
                            <span class="badge bg-danger">Đã diễn ra</span>
                        }
                    </p>
                    <a asp-action="DetailsTour" asp-route-id="@events.Id" class="btn btn-primary mt-auto">Chi tiết</a>
                </div>
            </div>
        </div>
    }
</div>

