@model Eventizo.ViewModel.HomePageViewModel
@using Microsoft.AspNetCore.Identity
@inject UserManager<Eventizo.Models.ApplicationUser> UserManager

@{
    ViewData["Title"] = "Home Page";
    var currentUser = User.Identity.IsAuthenticated ? await UserManager.GetUserAsync(User) : null;
    var userFullName = currentUser?.FullName ?? "bạn";
    var userId = currentUser?.Id ?? "guest";
}

<div id="eventCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="3000">

    <!-- Indicators/dots -->
    <div class="carousel-indicators">
        <button type="button" data-bs-target="#eventCarousel" data-bs-slide-to="0" class="active"></button>
        <button type="button" data-bs-target="#eventCarousel" data-bs-slide-to="1"></button>
        <button type="button" data-bs-target="#eventCarousel" data-bs-slide-to="2"></button>
    </div>

    <!-- The slideshow/carousel -->
    <div class="carousel-inner">
        <!-- Slide 1 -->
        <div class="carousel-item active">
            <div class="d-flex justify-content-center flex-nowrap">
                <img src="~/Images/concert/concert1.png" class="d-block w-50 p-2" alt="Concert 3">
                <img src="~/Images/liveshow/The rave awakens (liveshow).png" class="d-block w-50 p-2" alt="Concert 4">
            </div>
        </div>

        <!-- Slide 2 -->
        <div class="carousel-item">
            <div class="d-flex justify-content-center flex-nowrap">
                <img src="~/Images/tour/1.png" class="d-block w-50 p-2" alt="Concert 3">
                <img src="~/Images/tour/4.png" class="d-block w-50 p-2" alt="Concert 4">
            </div>
        </div>

        <!-- Slide 3 -->
        <div class="carousel-item">
            <div class="d-flex justify-content-center flex-nowrap">
                <img src="~/Images/liveshow/Sunset Serenade (liveshow).png" class="d-block w-50 p-2" alt="Concert 5">
                <img src="~/Images/Coming Soon.png" class="d-block w-50 p-2" alt="Concert 6">
            </div>
        </div>
    </div>

    <!-- Nút Previous -->
    <button class="carousel-control-prev" type="button" data-bs-target="#eventCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
    </button>

    <!-- Nút Next -->
    <button class="carousel-control-next" type="button" data-bs-target="#eventCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
    </button>

</div>

<!-- Swiper 1 -->
<div class="container text-start mt-4">
    <h2 class="custom-title">Sự kiện nổi bật</h2>
</div>

<div class="container">
    <div class="swiper mySwiper">
        <div class="swiper-wrapper">
            @foreach (var item in Model.UpcomingEvents)
            {
                var actionName = item.Event.EventType.Name switch
                {
                    "Concert" => "DetailsConcert",
                    "Tour" => "DetailsTour",
                    "Liveshow" => "DetailsLiveshow",
                    _ => "Details"
                };
                <div class="swiper-slide">
                    <a asp-controller="Home" asp-action="@actionName" asp-route-id="@item.Event.Id">
                        <img src="@item.Event.ImageUrl" alt="@item.Event.Name">
                        <div class="card-overlay">
                            <h5>@item.Event.Name</h5>
                            <p>@item.Event.EventStartingDate.ToString("dd/MM/yyyy")</p>
                        </div>
                    </a>
                </div>
            }

            <!-- Card 6 - Xem thêm -->
            <div class="swiper-slide">
                <a href="/Home/InMonth" class="card-link text-decoration-none">
                    <img src="~/Images/more.jpg" alt="Xem thêm">
                    <div class="card-overlay">
                        <h5>Xem thêm</h5>
                    </div>
                </a>
            </div>
        </div>

        <!-- Swiper Controls -->
        <div class="swiper-button-next"></div>
        <div class="swiper-button-prev"></div>
    </div>
</div>

