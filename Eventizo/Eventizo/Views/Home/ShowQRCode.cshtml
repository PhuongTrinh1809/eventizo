@model Eventizo.Models.Ticket

<h2 style="text-align:center; margin-bottom:20px;">Quét mã để xác nhận vé</h2>

<div style="text-align:center; margin-top:30px;">
    @if (ViewBag.QRCodeImage != null)
    {
        <img src="@ViewBag.QRCodeImage"
             alt="QR Code"
             style="width:250px; height:250px; border:4px solid #ff6185; border-radius:12px; padding:10px;" />
    }
    else
    {
        <p style="color:red; font-weight:bold;">Vé chưa được xác nhận hoặc chưa có mã QR.</p>
    }
</div>

<div style="text-align:center; margin-top:30px;">
    <a asp-controller="Home" asp-action="MyTickets" class="btn btn-primary">
        ⬅ Quay lại danh sách vé
    </a>
</div>