@model IEnumerable<Eventizo.Models.Event>

@{
    ViewData["Title"] = "Live Show";

    // Logic sắp xếp: GIỮ NGUYÊN
    var sortedEvents = Model
        .Where(e => e.EventType.Name == "Liveshow")
        .OrderBy(e => e.Status == "Sắp diễn ra" ? 1 :
                      e.Status == "Đang diễn ra" ? 2 :
                      3);
}

<div class="container py-5">
    <div class="d-flex align-items-center mb-4 border-bottom pb-3">
        <h2 class="fw-bold m-0" style="color: #6f42c1;">DANH SÁCH LIVESHOW</h2>
        <span class="ms-3 badge bg-secondary rounded-pill">@sortedEvents.Count() sự kiện</span>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var events in sortedEvents)
        {
            <div class="col">
                <div class="card h-100 shadow border-0 liveshow-card-hover rounded-4">

                    <div class="position-relative overflow-hidden rounded-top-4">
                        @if (!string.IsNullOrEmpty(events.ImageUrl))
                        {
                            <a asp-action="DetailsLiveshow" asp-controller="Home" asp-route-id="@events.Id">
                                <img src="@Url.Content(events.ImageUrl)" class="card-img-top liveshow-img-zoom" alt="@events.Name" />
                            </a>
                        }

                        <div class="position-absolute top-0 end-0 p-3">
                            @if (events.Status == "Sắp diễn ra")
                            {
                                <span class="badge bg-success shadow fs-6">Sắp diễn ra</span>
                            }
                            else if (events.Status == "Đang diễn ra")
                            {
                                <span class="badge bg-warning text-dark shadow fs-6">Đang diễn ra</span>
                            }
                            else if (events.Status == "Đã diễn ra")
                            {
                                <span class="badge bg-danger shadow fs-6">Đã diễn ra</span>
                            }
                        </div>
                    </div>

                    <div class="card-body d-flex flex-column text-center p-4">
                        <h5 class="card-title fw-bold text-dark title-clamp" title="@events.Name">
                            @events.Name
                        </h5>

                        <p class="card-text text-muted desc-clamp mb-3">
                            @events.Description
                        </p>

                        <div class="mt-auto w-100">
                            <a asp-action="DetailsLiveshow" asp-route-id="@events.Id" class="btn btn-purple w-100 py-2 fw-bold rounded-pill shadow-sm">
                                XEM CHI TIẾT
                            </a>
                        </div>
                    </div>

                </div>
            </div>
        }
    </div>
</div>

<style>
    /* 1. Cố định chiều cao ảnh 250px (Đồng nhất với Tour/Concert) */
    .card-img-top {
        height: 250px;
        width: 100%;
        object-fit: cover;
        transition: transform 0.6s ease;
    }

    /* 2. Hiệu ứng Zoom ảnh */
    .liveshow-card-hover:hover .liveshow-img-zoom {
        transform: scale(1.1);
    }

    /* 3. Hiệu ứng Card nổi lên */
    .liveshow-card-hover {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        background-color: #fff;
    }

        .liveshow-card-hover:hover {
            transform: translateY(-8px);
            box-shadow: 0 1rem 3rem rgba(0,0,0,.15) !important;
        }

    /* 4. Tên sự kiện To và giới hạn 2 dòng */
    .title-clamp {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        font-size: 1.35rem; /* ~22px: To và rõ */
        line-height: 1.3;
        height: 2.6em;
        margin-bottom: 0.5rem;
    }

    /* 5. Giới hạn Mô tả (3 dòng) để khung không bị dài ngắn lệch nhau */
    .desc-clamp {
        display: -webkit-box;
        -webkit-line-clamp: 3; /* Tối đa 3 dòng */
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-overflow: ellipsis;
        font-size: 0.95rem;
        height: 4.2em; /* Chiều cao cố định cho phần chữ */
    }

    /* 6. Button màu Tím (Custom Style) */
    .btn-purple {
        background-color: #6f42c1;
        border-color: #6f42c1;
        color: white;
    }

        .btn-purple:hover {
            background-color: #59359a;
            border-color: #59359a;
            color: white;
        }
</style>