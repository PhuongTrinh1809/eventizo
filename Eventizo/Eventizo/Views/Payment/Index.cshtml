@model Eventizo.Models.Payment
@{
    ViewData["Title"] = "Xác nhận và Thanh toán vé sự kiện";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">

<style>
    .custom-card {
        border-radius: 15px;
        box-shadow: 0 5px 30px rgba(255,97,133,0.4);
        padding: 25px;
        margin-bottom: 20px;
        background-color: #fff;
    }

    .info-label {
        font-weight: 600;
        color: #ff6185;
    }

    .section-title {
        text-align: center;
        margin-bottom: 20px;
        font-weight: 700;
        color: #ff6185;
    }

    .container {
        max-width: 950px;
    }

    .btn-payos {
        background-color: #007bff;
        border-color: #007bff;
        color: white;
        font-weight: bold;
        padding: 15px 30px;
        border-radius: 10px;
        transition: background-color 0.3s;
    }

        .btn-payos:hover {
            background-color: #0056b3;
            color: white;
        }

    .payment-instruction {
        padding: 20px;
        border: 1px dashed #ff6185;
        border-radius: 10px;
        margin-top: 20px;
    }

    .qr-container img {
        max-width: 250px;
        width: 100%;
        height: auto;
        display: block;
        margin: 0 auto;
    }
</style>

<div class="container py-5">
    <h2 class="text-center mb-4">Xác nhận và Thanh toán</h2>

    @if (Model?.Event != null && Model.TotalAmount > 0)
    {
        var seatList = Model.SelectedSeats?.Split(',', StringSplitOptions.RemoveEmptyEntries);
        var seatTypes = Model.TicketType?.Split(',', StringSplitOptions.RemoveEmptyEntries);

        if (seatList?.Length != seatTypes?.Length || seatList.Length == 0)
        {
            <div class="alert alert-danger text-center">
                <i class="bi bi-x-octagon-fill"></i> Dữ liệu thanh toán không hợp lệ. Vui lòng quay lại trang chọn ghế.
                <a asp-controller="Events" asp-action="Details" asp-route-id="@Model.EventId" class="alert-link">Quay lại sự kiện</a>
            </div>
        }
        else
        {
            <div class="row">
                <!-- Thông tin sự kiện -->
                <div class="col-md-6">
                    <div class="custom-card">
                        <h4 class="section-title">Thông tin sự kiện</h4>
                        <p><span class="info-label">Mã sự kiện:</span> @Model.Event.Id</p>
                        <p><span class="info-label">Tên sự kiện:</span> @Model.Event.Name</p>
                        <p><span class="info-label">Thời gian:</span> @Model.Event.EventStartingDate.ToString("dd/MM/yyyy")</p>
                        <p><span class="info-label">Địa điểm:</span> @Model.Event.Place</p>
                        <p><span class="info-label">Ghế đã chọn:</span> @Model.SelectedSeats</p>
                        <p><span class="info-label">Số lượng vé:</span> @Model.Quantity</p>
                        <hr />
                        <h5 class="info-label">Tổng tiền cần thanh toán:</h5>
                        <h3>@(Model.TotalAmount.ToString("N0")) VND</h3>
                    </div>
                </div>

                <!-- Thanh toán -->
                <div class="col-md-6 d-flex align-items-center justify-content-center">
                    <div class="custom-card text-center w-100">
                        <h4 class="section-title">Phương thức thanh toán</h4>

                        @{
                            var qrCodeImage = ViewData["QrCodeImage"] as string;
                            var paymentLinkUrl = ViewData["PaymentLink"] as string;
                            var orderCode = ViewData["OrderCode"]?.ToString();
                        }

                        @if (!User.Identity.IsAuthenticated)
                        {
                            <div class="alert alert-danger">
                                <i class="bi bi-person-fill"></i> Vui lòng <a asp-controller="Account" asp-action="Login">Đăng nhập</a> để tạo đơn hàng và QR Code thanh toán.
                            </div>
                        }
                        else if (!string.IsNullOrEmpty(qrCodeImage))
                        {
                            <div class="payment-instruction">
                                <i class="bi bi-qr-code-scan display-4 text-success"></i>
                                <p class="mt-2 lead">Quét mã VietQR để thanh toán</p>
                                <p class="text-muted">Mã đơn hàng: <strong>@orderCode</strong></p>
                            </div>

                            <div class="qr-container mt-4 mb-3">
                                <img src="@qrCodeImage" alt="VietQR PayOS" />
                            </div>

                            <p class="text-center text-muted">Hoặc chuyển khoản qua Ngân hàng/Ví điện tử</p>

                            <a href="@paymentLinkUrl" target="_blank" class="btn btn-payos btn-lg mt-3">
                                <i class="bi bi-credit-card-fill"></i> THANH TOÁN BẰNG THẺ/VÍ (Chuyển đến PayOS)
                            </a>

                            <p class="text-small text-muted mt-2">Đơn hàng sẽ tự động hủy sau 15 phút nếu chưa thanh toán.</p>
                        }
                        else
                        {
                            <div class="alert alert-warning">
                                <i class="bi bi-exclamation-triangle-fill"></i> Lỗi tạo mã thanh toán. Vui lòng thử lại.
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="alert alert-warning text-center">
            <i class="bi bi-exclamation-triangle-fill"></i> Không tìm thấy thông tin sự kiện hoặc tổng tiền không hợp lệ.
        </div>
    }
</div>
